# ========================================
# LabBridge — .gitignore
# Covers: Python/FastAPI, Next.js, Node, IDEs
# ========================================

# ---------- Environment & Secrets ----------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ---------- Python / FastAPI Backend ----------
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
env/
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
*.egg
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# ---------- Next.js / Node Frontend ----------
node_modules/
.next/
out/
.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ---------- IDE & Editors ----------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ---------- OS Files ----------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ---------- Testing & Coverage ----------
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.lcov
.hypothesis/
.pytest_cache/

# ---------- Misc ----------
*.log
*.bak
*.tmp
*.temp